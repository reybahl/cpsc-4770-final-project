{
  "name": "@formagent/api",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    },
    "./eval": {
      "default": "./src/lib/eval-exports.ts"
    }
  },
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "dev": "tsc",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "eslint --flag unstable_native_nodejs_ts_config",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.41",
    "@browserbasehq/sdk": "^2.8.0",
    "@browserbasehq/stagehand": "^3.1.0",
    "@formagent/auth": "workspace:*",
    "@formagent/db": "workspace:*",
    "@formagent/validators": "workspace:*",
    "@supabase/supabase-js": "^2.99.0",
    "@trpc/server": "catalog:",
    "ai": "^6.0.116",
    "superjson": "2.2.3",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@formagent/eslint-config": "workspace:*",
    "@formagent/prettier-config": "workspace:*",
    "@formagent/tsconfig": "workspace:*",
    "@types/pg": "^8.11.10",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:"
  },
  "prettier": "@formagent/prettier-config"
}
