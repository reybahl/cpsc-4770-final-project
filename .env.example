# Since .env is gitignored, you can use .env.example to build a new `.env` file when you clone the repo.
# Keep this file up-to-date when you add new variables to \`.env\`.

# This file will be committed to version control, so make sure not to have any secrets in it.
# If you are cloning this repo, create a copy of this file named `.env` and populate it with your secrets.

# Database connection (works with local Postgres, Supabase, Neon, etc.)
POSTGRES_URL="postgresql://user:password@localhost:5432/postgres"


# You can generate the secret via 'openssl rand -base64 32' on Unix
# @see https://www.better-auth.com/docs/installation
AUTH_SECRET='supersecret'

# Supabase - get these from https://supabase.com/dashboard/project/_/settings/api
# Create a bucket named "resumes" in Storage (public for now)
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# OpenAI - for AI SDK PDF extraction
OPENAI_API_KEY=sk-...

# Eval: model that predicts field values from static HTML before Playwright fills the form (default gpt-4.1-mini)
# EVAL_BASELINE_MODEL=gpt-4.1-mini

# Browserbase (optional) - for cloud browser sessions. When set, the form-fill agent uses
# Browserbase instead of local Chrome. Get from https://browserbase.com
# If not set, falls back to local Chromium.
BROWSERBASE_API_KEY=bb_...
BROWSERBASE_PROJECT_ID=...